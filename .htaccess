# лабораторная работа №2 — настройки Apache для локальной разработки

# запретить листинг папок (чтобы нельзя было смотреть список файлов)
Options -Indexes

# показывать ошибки PHP — удобно при отладке на своём компьютере
# на хостинге перед сдачей это лучше выключить
php_flag display_errors On
php_value error_reporting E_ALL
